# ==========================================
# NOC MCP Server - Environment Configuration
# ==========================================

# Puerto en el que el contenedor expondrá el servicio internamente
PORT=8080

# API Key para proteger el endpoint del MCP Server
MCP_API_KEY=super-secret-noc-key-cambiar-en-produccion

# Credenciales Telnet por defecto para los switches (si la tool no envía switch_user / switch_pass)
# Si no las defines, el servidor usa allied / 4ll13d
NOC_SWITCH_USER=
NOC_SWITCH_PASSWORD=

# Zona horaria del contenedor (útil para que los logs del servidor coincidan con tu hora local)
TZ=America/Bogota